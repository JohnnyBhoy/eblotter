{
  "name": "eblotter-server",
  "version": "1.0.0",
  "description": "Barangay e-Blotter System - Backend",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon --exec tsx server.ts",
    "build": "tsc && cp -r data dist/data",
    "start": "node dist/server.js",
    "seed": "tsx seed/seedData.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/pdfkit": "^0.17.6",
    "nodemon": "^3.1.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
